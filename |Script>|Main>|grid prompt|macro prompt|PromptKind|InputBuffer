14723:    /// <summary>
14724:    /// Rebuilds the Scripts top-level menu from the configured scripts directory.
14725:    /// Disk scanning runs on a background thread; MenuItem objects are created
14726:    /// on the UI thread in the continuation.
14727:    /// </summary>
14728:    private void RebuildScriptsMenu()
14729:    {
14730:        var reloadItem = new MenuItem { Header = "_Reload All Scripts" };
14731:        reloadItem.Click += (_, _) => RebuildScriptsMenu();
14732:
14733:        var dir = _appPrefs.ScriptsDirectory;
14734:
14735:        if (string.IsNullOrWhiteSpace(dir) || !Directory.Exists(dir))
14736:        {
14737:            var msg = !string.IsNullOrWhiteSpace(dir)
14738:                ? "Scripts directory not found"
14739:                : "No scripts directory configured";
14740:            _scriptsMenu.ItemsSource = new List<object>
14741:            {
14742:                reloadItem, new Separator(),
14743:                new MenuItem { Header = msg, IsEnabled = false },
14744:            };
14745:            RefreshNativeAppMenu();
14746:            return;
14747:        }
14748:
14749:        // Show placeholder while scanning
14750:        _scriptsMenu.ItemsSource = new List<object>
14751:        {
14752:            reloadItem, new Separator(),
14753:            new MenuItem { Header = "Scanning…", IsEnabled = false },
14754:        };
14755:
14756:        var baseDir = dir.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar, ' ');
14757:
14758:        _ = Task.Run(() => ScanScriptNodes(baseDir, baseDir, depth: 0))
14759:                .ContinueWith(t =>
14760:                {
14761:                    if (t.IsFaulted) return;
14762:
14763:                    var items = new List<object> { reloadItem, new Separator() };
14764:                    if (t.Result.Count == 0)
14765:                        items.Add(new MenuItem { Header = "(no scripts found)", IsEnabled = false });
14766:                    else
14767:                        BuildMenuItems(items, t.Result);
14768:
14769:                    _scriptsMenu.ItemsSource = items;
14770:                    RefreshNativeAppMenu();
14771:                }, TaskScheduler.FromCurrentSynchronizationContext());
14772:    }
