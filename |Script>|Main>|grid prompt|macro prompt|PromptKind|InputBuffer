15029:    private static string NormalizeNativeMenuHeader(string? header)
15030:    {
15031:        if (string.IsNullOrWhiteSpace(header))
15032:            return string.Empty;
15033:
15034:        var sb = new System.Text.StringBuilder(header.Length);
15035:        for (int i = 0; i < header.Length; i++)
15036:        {
15037:            if (header[i] != '_')
15038:            {
15039:                sb.Append(header[i]);
15040:                continue;
15041:            }
15042:
15043:            if (i + 1 < header.Length && header[i + 1] == '_')
15044:            {
15045:                sb.Append('_');
15046:                i++;
15047:            }
15048:        }
15049:
15050:        return sb.ToString();
15051:    }
