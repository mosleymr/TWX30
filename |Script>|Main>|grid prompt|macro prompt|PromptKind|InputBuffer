13891:        string normalized = loadReference.Trim().Replace('\\', '/');
13892:        string directPath = ResolveMombotFilePath(normalized);
13893:        if (File.Exists(directPath))
13894:            return normalized;
13895:
13896:        if (!normalized.StartsWith("scripts/", StringComparison.OrdinalIgnoreCase))
13897:        {
13898:            string prefixed = "scripts/" + normalized.TrimStart('/');
13899:            if (File.Exists(ResolveMombotFilePath(prefixed)))
13900:                return prefixed;
13901:        }
13902:
13903:        return normalized;
13904:    }
