7837:    private int StopScriptsForBotTree(string origin, Core.BotConfig config, string lastLoadedModule, string scriptDirectory, string programDir)
7838:    {
7839:        IReadOnlyList<string> directScriptPaths = GetConfiguredBotScriptPaths(config, scriptDirectory);
7840:        string? scriptRootPath = GetConfiguredBotScriptRootPath(config, scriptDirectory);
