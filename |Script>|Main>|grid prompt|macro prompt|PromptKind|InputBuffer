1119:    private static double GetBestDeckSnap(double proposed, IEnumerable<double> targets)
1120:    {
1121:        double snapped = proposed;
1122:        double bestDistance = DeckPanelSnapThreshold + 0.001;
1123:
1124:        foreach (double target in targets)
1125:        {
1126:            double distance = Math.Abs(target - proposed);
1127:            if (distance > DeckPanelSnapThreshold || distance >= bestDistance)
1128:                continue;
1129:
1130:            snapped = target;
1131:            bestDistance = distance;
1132:        }
1133:
1134:        return snapped;
1135:    }
