7926:    private static string? GetConfiguredBotScriptRootPath(Core.BotConfig config, string scriptDirectory)
7927:    {
7928:        string script = config.ScriptFiles.Count > 0
7929:            ? config.ScriptFiles[0]
7930:            : config.ScriptFile;
7931:        if (string.IsNullOrWhiteSpace(script))
7932:            return null;
7933:
7934:        string normalized = script.Replace('\\', Path.DirectorySeparatorChar).Replace('/', Path.DirectorySeparatorChar).Trim();
7935:        string? directory = Path.GetDirectoryName(normalized);
7936:        if (string.IsNullOrWhiteSpace(directory))
7937:            return Path.GetFullPath(scriptDirectory);
7938:
7939:        return Path.GetFullPath(Path.IsPathRooted(directory)
7940:            ? directory
7941:            : Path.Combine(scriptDirectory, directory));
