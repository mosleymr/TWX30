10866:    private static string EncodeTemporaryMacroBytes(IEnumerable<byte> bytes)
10867:    {
10868:        var builder = new System.Text.StringBuilder();
10869:        foreach (byte value in bytes)
10870:        {
10871:            switch (value)
10872:            {
10873:                case (byte)'\r':
10874:                    builder.Append('*');
10875:                    break;
10876:                case (byte)'*':
10877:                    builder.Append(@"\*");
10878:                    break;
10879:                case (byte)'\\':
10880:                    builder.Append(@"\\");
10881:                    break;
10882:                default:
10883:                    if (value is >= 32 and <= 126)
10884:                        builder.Append((char)value);
10885:                    else
10886:                        builder.Append(@"\x").Append(value.ToString("X2"));
10887:                    break;
10888:            }
10889:        }
10890:
10891:        return builder.ToString();
10892:    }
