905:        double fullBodyHeight = Math.Max(300, surfaceHeight - 94);
906:        double mapWidth = Math.Clamp(availableWidth * 0.38, 300, 560);
907:        double consoleLeft = horizontalMargin + mapWidth + panelGap;
908:        double consoleWidth = Math.Max(420, surfaceWidth - consoleLeft - horizontalMargin);
909:
910:        return panelId switch
911:        {
912:            "map" => new DeckPanelState
913:            {
914:                PanelId = panelId,
915:                Left = horizontalMargin,
916:                Top = 18,
917:                Width = mapWidth,
918:                BodyHeight = fullBodyHeight,
919:                ZIndex = 110,
