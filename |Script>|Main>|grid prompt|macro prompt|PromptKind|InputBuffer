9789:    private static IReadOnlyList<string> BuildMombotConfigLines(MombotHotkeyConfigData config)
9790:    {
9791:        var lines = new string[33];
9792:        for (int slot = 1; slot <= 33; slot++)
9793:        {
9794:            string key = slot <= config.CustomKeys.Length ? config.CustomKeys[slot - 1] : "0";
9795:            string command = slot <= config.CustomCommands.Length ? config.CustomCommands[slot - 1] : "0";
9796:            if (string.IsNullOrWhiteSpace(command))
9797:                command = "0";
9798:            lines[slot - 1] = $"{slot}${EncodeMombotHotkeyToken(key)}${command}";
