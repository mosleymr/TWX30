9778:        {
9779:            "\t" => "TAB",
9780:            "\r" => "ENTER",
9781:            "\b" => "BACKSPACE",
9782:            " " => "SPACE",
9783:            "" => "0",
9784:            "0" => "0",
9785:            _ => key[..1],
9786:        };
9787:    }
