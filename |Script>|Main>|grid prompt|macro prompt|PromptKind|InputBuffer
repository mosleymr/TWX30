13128:    private static bool TryParseMombotCatalogLine(string line, int fixedFieldCount, out string[] fields, out string trailingName)
13129:    {
13130:        fields = Array.Empty<string>();
13131:        trailingName = string.Empty;
13132:        if (string.IsNullOrWhiteSpace(line))
13133:            return false;
13134:
13135:        string[] tokens = line.Split(' ', StringSplitOptions.RemoveEmptyEntries);
13136:        if (tokens.Length < fixedFieldCount + 1)
13137:            return false;
13138:
13139:        fields = tokens.Take(fixedFieldCount).ToArray();
13140:        trailingName = string.Join(" ", tokens.Skip(fixedFieldCount));
13141:        return !string.IsNullOrWhiteSpace(trailingName);
13142:    }
