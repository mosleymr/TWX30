9727:    private static string[] BuildMombotHotkeyIndex(IReadOnlyList<string> customKeys)
9728:    {
9729:        string[] hotkeys = Enumerable.Repeat("0", 255).ToArray();
9730:        for (int slot = 1; slot <= Math.Min(33, customKeys.Count); slot++)
9731:        {
9732:            string keyToken = customKeys[slot - 1];
9733:            if (!TryDecodeMombotHotkeyToken(keyToken, out string normalizedKey) ||
9734:                string.IsNullOrWhiteSpace(normalizedKey) ||
9735:                normalizedKey == "0")
9736:            {
9737:                continue;
9738:            }
9739:
9740:            char hotkey = normalizedKey[0];
9741:            int lower = char.ToLowerInvariant(hotkey);
9742:            int upper = char.ToUpperInvariant(hotkey);
9743:            if (lower >= 1 && lower <= hotkeys.Length)
9744:                hotkeys[lower - 1] = slot.ToString();
9745:            if (upper >= 1 && upper <= hotkeys.Length)
9746:                hotkeys[upper - 1] = slot.ToString();
9747:        }
9748:
9749:        return hotkeys;
9750:    }
