14866:    /// <summary>Returns true if <paramref name="dir"/> (or any sub-dir within
14867:    /// <paramref name="remainingDepth"/> levels) contains at least one .ts or .cts file.</summary>
14868:    private static bool DirectoryHasScripts(string dir, int remainingDepth)
14869:    {
14870:        try
14871:        {
14872:            if (Directory.EnumerateFiles(dir, "*.ts",  SearchOption.TopDirectoryOnly).Any()) return true;
14873:            if (Directory.EnumerateFiles(dir, "*.cts", SearchOption.TopDirectoryOnly).Any()) return true;
14874:            if (remainingDepth > 0)
14875:                foreach (var sub in Directory.EnumerateDirectories(dir))
14876:                    if (DirectoryHasScripts(sub, remainingDepth - 1)) return true;
14877:        }
14878:        catch { /* ignore */ }
14879:        return false;
14880:    }
