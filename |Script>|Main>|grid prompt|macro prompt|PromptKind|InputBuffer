1057:    private static void ApplyDeckPanelState(FloatingDeckPanel panel, DeckPanelState state)
1058:    {
1059:        panel.ZIndex = state.ZIndex;
1060:        panel.SetClosed(false);
1061:        panel.SetMinimized(false);
1062:        panel.MoveTo(state.Left, state.Top, clampToHost: false);
1063:        if (state.Minimized)
1064:            panel.SetMinimized(true);
1065:        if (state.Closed)
1066:            panel.SetClosed(true);
1067:    }
