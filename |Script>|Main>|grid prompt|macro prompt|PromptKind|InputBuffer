14076:    private async Task RestoreCurrentGamePromptAfterMombotCommandAsync(
14077:        IReadOnlyList<MTC.mombot.mombotDispatchResult> results,
14078:        string promptAnsi,
14079:        string promptPlain,
14080:        int promptVersionBefore)
14081:    {
14082:        if (string.IsNullOrWhiteSpace(promptPlain))
14083:            return;
14084:
14085:        string[] pendingScriptReferences = results
14086:            .Where(result => result.Kind == MTC.mombot.mombotDispatchKind.Script &&
14087:                             !string.IsNullOrWhiteSpace(result.ScriptReference))
14088:            .Select(result => result.ScriptReference!)
14089:            .Distinct(StringComparer.OrdinalIgnoreCase)
14090:            .ToArray();
14091:
14092:        int restoreTicket = ++_mombotPromptRestoreTicket;
14093:        DateTime restoreDeadlineUtc = DateTime.UtcNow.AddHours(8);
14094:        while (DateTime.UtcNow < restoreDeadlineUtc)
14095:        {
14096:            await Task.Delay(100).ConfigureAwait(false);
14097:
14098:            if (restoreTicket != _mombotPromptRestoreTicket)
14099:                return;
14100:
14101:            if (_gameInstance == null ||
14102:                !_gameInstance.IsConnected ||
14103:                _gameInstance.IsProxyMenuActive ||
14104:                !_mombot.Enabled)
14105:            {
14106:                return;
14107:            }
14108:
14109:            if (pendingScriptReferences.Any(IsMombotScriptStillRunning))
14110:                continue;
14111:
14112:            long lastServerOutputUtcTicks = Interlocked.Read(ref _mombotLastServerOutputUtcTicks);
14113:            if (lastServerOutputUtcTicks > 0)
14114:            {
14115:                DateTime lastServerOutputUtc = new(lastServerOutputUtcTicks, DateTimeKind.Utc);
14116:                if ((DateTime.UtcNow - lastServerOutputUtc) < TimeSpan.FromMilliseconds(300))
14117:                    continue;
14118:            }
14119:
14120:            await Dispatcher.UIThread.InvokeAsync(() =>
14121:            {
14122:                string candidatePromptAnsi = promptAnsi;
14123:                string candidatePromptPlain = promptPlain;
14124:
14125:                if (restoreTicket != _mombotPromptRestoreTicket)
14126:                    return;
14127:
14128:                if (_mombotObservedGamePromptVersion != promptVersionBefore &&
14129:                    !string.IsNullOrWhiteSpace(_mombotLastObservedGamePromptPlain))
14130:                {
14131:                    candidatePromptAnsi = _mombotLastObservedGamePromptAnsi;
14132:                    candidatePromptPlain = _mombotLastObservedGamePromptPlain;
14133:                }
14134:
14135:                if (string.IsNullOrWhiteSpace(candidatePromptPlain))
14136:                    return;
14137:
14138:                if (IsTerminalCurrentLineEquivalentTo(candidatePromptPlain))
14139:                    return;
14140:
14141:                if (!IsTerminalCurrentLineBlank())
14142:                    return;
14143:
14144:                AppendCurrentGamePrompt(candidatePromptAnsi, candidatePromptPlain);
14145:            });
14146:            return;
14147:        }
14148:    }
