10894:    private string? ValidateTemporaryMacroText(string macroText)
10895:    {
10896:        if (string.IsNullOrWhiteSpace(macroText))
10897:            return "Enter a macro before playback.";
10898:
10899:        if (macroText.Length > TemporaryMacroMaxCharacters)
10900:            return $"Temporary macros are limited to {TemporaryMacroMaxCharacters} characters.";
10901:
10902:        return TryDecodeTemporaryMacroText(macroText, out _, out string? error)
10903:            ? null
10904:            : error ?? "Macro text is invalid.";
