9715:    private static string[] NormalizeMombotCustomLines(string[] source, int count)
9716:    {
9717:        string[] normalized = Enumerable.Repeat("0", count).ToArray();
9718:        for (int i = 0; i < Math.Min(count, source.Length); i++)
9719:        {
9720:            string value = source[i].Trim();
9721:            normalized[i] = string.IsNullOrWhiteSpace(value) ? "0" : value;
9722:        }
9723:
9724:        return normalized;
