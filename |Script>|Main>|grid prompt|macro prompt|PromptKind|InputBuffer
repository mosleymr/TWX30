10907:    private static bool TryDecodeTemporaryMacroText(string macroText, out byte[] bytes, out string? error)
10908:    {
10909:        var values = new List<byte>(macroText.Length);
10910:
10911:        for (int index = 0; index < macroText.Length; index++)
10912:        {
10913:            char current = macroText[index];
10914:            if (current == '*')
10915:            {
10916:                values.Add((byte)'\r');
10917:                continue;
10918:            }
10919:
10920:            if (current != '\\')
10921:            {
10922:                if (current > byte.MaxValue)
10923:                {
10924:                    bytes = [];
10925:                    error = "Temporary macros support Latin-1 text only.";
10926:                    return false;
10927:                }
10928:
10929:                values.Add((byte)current);
10930:                continue;
10931:            }
10932:
10933:            if (index == macroText.Length - 1)
10934:            {
10935:                bytes = [];
10936:                error = "A backslash must be followed by \\\\, \\*, or \\xNN.";
10937:                return false;
10938:            }
10939:
10940:            char next = macroText[++index];
10941:            switch (next)
10942:            {
10943:                case '\\':
10944:                    values.Add((byte)'\\');
10945:                    break;
10946:                case '*':
10947:                    values.Add((byte)'*');
10948:                    break;
10949:                case 'x':
10950:                case 'X':
10951:                    if (index + 2 >= macroText.Length ||
10952:                        !byte.TryParse(macroText.Substring(index + 1, 2), System.Globalization.NumberStyles.HexNumber, null, out byte hexValue))
10953:                    {
10954:                        bytes = [];
10955:                        error = "Use \\x followed by two hex digits.";
10956:                        return false;
10957:                    }
10958:
10959:                    values.Add(hexValue);
10960:                    index += 2;
10961:                    break;
10962:                default:
10963:                    bytes = [];
10964:                    error = "A backslash must be followed by \\\\, \\*, or \\xNN.";
10965:                    return false;
10966:            }
10967:        }
10968:
10969:        bytes = values.ToArray();
10970:        error = null;
10971:        return true;
10972:    }
