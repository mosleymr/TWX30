8001:    private static bool IsScriptUnderRoot(string scriptPath, string scriptRootPath)
8002:    {
8003:        if (string.IsNullOrWhiteSpace(scriptPath) || string.IsNullOrWhiteSpace(scriptRootPath))
8004:            return false;
8005:
8006:        string normalizedRoot = scriptRootPath.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
8007:        if (string.Equals(scriptPath, normalizedRoot, StringComparison.OrdinalIgnoreCase))
8008:            return true;
8009:
8010:        string prefix = normalizedRoot + Path.DirectorySeparatorChar;
8011:        return scriptPath.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
8012:    }
