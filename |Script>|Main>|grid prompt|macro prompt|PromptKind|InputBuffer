3636:
3637:        if (string.IsNullOrEmpty(payload))
3638:            return;
3639:
3640:        _commEntries.Add(new CommEntry(_commSelectedChannel, string.Empty, message, IsLocal: true));
3641:        if (_commEntries.Count > MaxCommEntries)
3642:            _commEntries.RemoveAt(0);
3643:        RefreshCommWindowText();
3644:
3645:        await SendCommPayloadAsync(payload);
3646:
