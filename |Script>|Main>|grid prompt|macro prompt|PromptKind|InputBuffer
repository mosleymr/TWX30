14774:    /// <summary>
14775:    /// Pure data scan — no Avalonia/UI objects created.  Safe on any thread.
14776:    /// Directories are listed before files at every level.
14777:    /// </summary>
14778:    private static List<ScriptNode> ScanScriptNodes(string dir, string baseDir, int depth)
14779:    {
14780:        const int MaxDepth = 5;
14781:        var nodes = new List<ScriptNode>();
14782:
14783:        // ── Subdirectories first ───────────────────────────────────────
14784:        if (depth < MaxDepth)
14785:        {
14786:            try
14787:            {
14788:                var subdirs = Directory
14789:                    .EnumerateDirectories(dir)
14790:                    .OrderBy(d => Path.GetFileName(d), StringComparer.OrdinalIgnoreCase);
14791:
14792:                foreach (var sub in subdirs)
14793:                {
14794:                    if (!DirectoryHasScripts(sub, MaxDepth - depth - 1)) continue;
14795:                    var children = ScanScriptNodes(sub, baseDir, depth + 1);
14796:                    if (children.Count == 0) continue;
14797:                    nodes.Add(new ScriptNode(
14798:                        IsDir: true, Name: Path.GetFileName(sub),
14799:                        RelPath: string.Empty, Children: children));
14800:                }
14801:            }
14802:            catch { /* permission denied */ }
14803:        }
14804:
14805:        // ── Script files ───────────────────────────────────────────────
14806:        try
14807:        {
14808:            var files = Directory
14809:                .EnumerateFiles(dir, "*.ts",  SearchOption.TopDirectoryOnly)
14810:                .Concat(Directory.EnumerateFiles(dir, "*.cts", SearchOption.TopDirectoryOnly))
14811:                .OrderBy(f => Path.GetFileName(f), StringComparer.OrdinalIgnoreCase);
14812:
14813:            foreach (var fp in files)
14814:                nodes.Add(new ScriptNode(
14815:                    IsDir: false, Name: Path.GetFileName(fp),
14816:                    RelPath: StripRelativePrefix(
14817:                               Path.GetRelativePath(baseDir, fp).Replace('\\', '/')),
14818:                    Children: []));
14819:        }
14820:        catch { /* permission denied */ }
14821:
14822:        return nodes;
14823:    }
