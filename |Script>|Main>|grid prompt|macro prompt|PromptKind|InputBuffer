11135:
11136:        if (_mombotScriptPromptOpen)
11137:            return TryHandleMombotScriptPromptInput(bytes);
11138:
11139:        if (_mombotHotkeyPromptOpen)
11140:            return TryHandleMombotHotkeyPromptInput(bytes);
11141:
11142:        if (_mombotMacroPromptOpen)
11143:            return TryHandleMombotMacroPromptInput(bytes);
11144:
11145:        if (!_mombotPromptOpen)
11146:            return false;
