7911:    private static IReadOnlyList<string> GetConfiguredBotScriptPaths(Core.BotConfig config, string scriptDirectory)
7912:    {
7913:        IReadOnlyList<string> scripts = config.ScriptFiles.Count > 0
7914:            ? config.ScriptFiles
7915:            : string.IsNullOrWhiteSpace(config.ScriptFile)
7916:                ? Array.Empty<string>()
7917:                : new[] { config.ScriptFile };
7918:
7919:        return scripts
7920:            .Where(script => !string.IsNullOrWhiteSpace(script))
7921:            .Select(script => NormalizeScriptStopPath(script, scriptDirectory, scriptDirectory))
