5671:                        // even while a proxy menu is open, otherwise waitfor/text triggers stall.
5672:                        interpreter.TextEvent(scriptRemainder, false);
5673:                        if (!string.IsNullOrWhiteSpace(strippedRemainder))
5674:                        {
