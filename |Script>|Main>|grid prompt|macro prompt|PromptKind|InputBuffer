14979:    private static NativeMenuItemBase? ConvertToNativeMenuItem(object? item)
14980:    {
14981:        if (item is Separator)
14982:            return new NativeMenuItemSeparator();
14983:
14984:        if (item is not MenuItem menuItem)
14985:            return null;
14986:
14987:        var nativeItem = new NativeMenuItem
14988:        {
14989:            Header = NormalizeNativeMenuHeader(menuItem.Header?.ToString()),
14990:            IsEnabled = menuItem.IsEnabled,
14991:            IsVisible = menuItem.IsVisible,
14992:        };
14993:
14994:        var children = GetMenuChildren(menuItem)
14995:            .Select(ConvertToNativeMenuItem)
14996:            .Where(child => child != null)
14997:            .Cast<NativeMenuItemBase>()
14998:            .ToList();
14999:
15000:        if (children.Count > 0)
15001:        {
15002:            var submenu = new NativeMenu();
15003:            foreach (NativeMenuItemBase child in children)
15004:                submenu.Add(child);
15005:            nativeItem.Menu = submenu;
15006:        }
15007:        else
15008:        {
15009:            nativeItem.Click += (_, _) =>
15010:                menuItem.RaiseEvent(new Avalonia.Interactivity.RoutedEventArgs(MenuItem.ClickEvent));
15011:        }
15012:
15013:        return nativeItem;
15014:    }
