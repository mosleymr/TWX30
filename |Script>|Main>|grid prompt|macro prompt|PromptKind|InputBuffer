7944:    private static bool ScriptReferenceMatches(string left, string right, string scriptDirectory, string programDir)
7945:    {
7946:        string leftScriptDir = NormalizeScriptStopPath(left, scriptDirectory, programDir);
7947:        string rightScriptDir = NormalizeScriptStopPath(right, scriptDirectory, programDir);
7948:        if (leftScriptDir.Equals(rightScriptDir, StringComparison.OrdinalIgnoreCase))
7949:            return true;
7950:
7951:        string leftProgramDir = NormalizeScriptStopPath(left, programDir, scriptDirectory);
7952:        string rightProgramDir = NormalizeScriptStopPath(right, programDir, scriptDirectory);
7953:        if (leftProgramDir.Equals(rightProgramDir, StringComparison.OrdinalIgnoreCase))
7954:            return true;
7955:
7956:        string leftLeaf = Path.GetFileName(left.Replace('\\', Path.DirectorySeparatorChar).Replace('/', Path.DirectorySeparatorChar).Trim());
7957:        string rightLeaf = Path.GetFileName(right.Replace('\\', Path.DirectorySeparatorChar).Replace('/', Path.DirectorySeparatorChar).Trim());
7958:        return !string.IsNullOrWhiteSpace(leftLeaf) &&
7959:               leftLeaf.Equals(rightLeaf, StringComparison.OrdinalIgnoreCase);
7960:    }
