14856:    /// <summary>Strips a leading <c>./</c> produced by <see cref="Path.GetRelativePath"/>
14857:    /// when the file is directly inside the base directory, then trims whitespace.</summary>
14858:    private static string StripRelativePrefix(string rel)
14859:    {
14860:        rel = rel.Trim();
14861:        if (rel.StartsWith("./") || rel.StartsWith(".\\"))
14862:            rel = rel[2..].TrimStart('/', '\\');
14863:        return rel;
