1094:    private IEnumerable<double> GetDeckVerticalSnapTargets(FloatingDeckPanel movingPanel, double proposedLeft, double proposedTop, double movingWidth, double movingHeight)
1095:    {
1096:        yield return 0;
1097:        if (_deckSurface != null)
1098:            yield return Math.Max(0, _deckSurface.Bounds.Height - movingHeight);
1099:        yield return SnapToDeckGrid(proposedTop);
1100:
1101:        foreach (FloatingDeckPanel panel in _deckPanels.Values)
1102:        {
1103:            if (panel == movingPanel || !panel.IsVisible)
1104:                continue;
1105:
1106:            (double left, double top) = panel.GetPosition();
1107:            double right = left + panel.PanelWidth;
1108:            double bottom = top + panel.PanelHeight;
1109:            if (!RangesOverlapOrNear(proposedLeft, proposedLeft + movingWidth, left, right, DeckPanelSnapThreshold * 2))
1110:                continue;
1111:
1112:            yield return top;
1113:            yield return bottom - movingHeight;
1114:            yield return bottom + DeckPanelSnapGap;
1115:            yield return top - movingHeight - DeckPanelSnapGap;
1116:        }
1117:    }
