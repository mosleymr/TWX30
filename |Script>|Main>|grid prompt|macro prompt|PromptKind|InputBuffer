13843:    private IReadOnlyList<MombotHotkeyScriptEntry> LoadMombotHotkeyScripts()
13844:    {
13845:        string filePath = ResolveMombotCurrentFilePath("$SCRIPT_FILE");
13846:        if (string.IsNullOrWhiteSpace(filePath) || !File.Exists(filePath))
13847:            return Array.Empty<MombotHotkeyScriptEntry>();
13848:
13849:        var scripts = new List<MombotHotkeyScriptEntry>();
13850:        try
13851:        {
13852:            int slot = 1;
13853:            foreach (string rawLine in File.ReadLines(filePath))
13854:            {
13855:                if (slot > 10)
13856:                    break;
13857:
13858:                string line = rawLine.Trim();
13859:                if (string.IsNullOrWhiteSpace(line))
13860:                    continue;
13861:
13862:                int quoteIndex = line.IndexOf('"');
13863:                if (quoteIndex <= 0)
13864:                    continue;
13865:
13866:                string loadReference = NormalizeMombotHotkeyScriptReference(line[..quoteIndex].Trim());
13867:                string displayName = line[quoteIndex..].Trim().Trim('"').Trim();
13868:                if (string.IsNullOrWhiteSpace(loadReference))
13869:                    continue;
13870:
13871:                scripts.Add(new MombotHotkeyScriptEntry(
13872:                    slot,
13873:                    loadReference,
13874:                    string.IsNullOrWhiteSpace(displayName) ? Path.GetFileNameWithoutExtension(loadReference) : displayName));
13875:                slot++;
13876:            }
13877:        }
13878:        catch
13879:        {
13880:            return Array.Empty<MombotHotkeyScriptEntry>();
13881:        }
13882:
13883:        return scripts;
13884:    }
