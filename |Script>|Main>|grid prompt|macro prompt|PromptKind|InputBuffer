10826:    private Task<string?> PlayTemporaryMacroBurstAsync(IReadOnlyList<byte[]> macroChunks, int count)
10827:    {
10828:        if (macroChunks.Count == 0 || macroChunks.All(chunk => chunk.Length == 0))
10829:            return Task.FromResult<string?>("Temporary macro is empty.");
10830:
10831:        if (!HasActiveMacroConnection())
10832:            return Task.FromResult<string?>("Temporary macros need an active game connection.");
10833:
10834:        Action<byte[]>? send = _terminalInputHandler;
10835:        if (send == null)
10836:            return Task.FromResult<string?>("Temporary macros need an active game connection.");
10837:
10838:        byte[] macroPayload = GetCombinedMacroPayload(macroChunks);
10839:        if (macroPayload.Length == 0)
10840:            return Task.FromResult<string?>("Temporary macro is empty.");
10841:
10842:        if (!TryBuildRepeatedMacroPayload(macroPayload, count, out byte[] burstPayload, out string? burstError))
10843:            return Task.FromResult<string?>(burstError ?? "Temporary macro burst is invalid.");
10844:
10845:        _suppressTemporaryMacroRecording = true;
10846:        try
10847:        {
