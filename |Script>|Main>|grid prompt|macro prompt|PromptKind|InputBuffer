10105:    private bool ShouldSuppressPendingNativeMombotEscapeEcho(byte value)
10106:    {
10107:        if (value != 0x1B)
10108:            return false;
10109:
10110:        int pending = Interlocked.CompareExchange(ref _pendingNativeMombotEscapeEchoSuppressions, 0, 0);
10111:        if (pending <= 0)
10112:            return false;
10113:
10114:        long suppressUntilTicks = Interlocked.Read(ref _nativeMombotEscapeEchoSuppressUntilUtcTicks);
10115:        if (suppressUntilTicks <= 0 || DateTime.UtcNow.Ticks > suppressUntilTicks)
10116:        {
10117:            Interlocked.Exchange(ref _pendingNativeMombotEscapeEchoSuppressions, 0);
10118:            Interlocked.Exchange(ref _nativeMombotEscapeEchoSuppressUntilUtcTicks, 0);
10119:            return false;
10120:        }
10121:
10122:        if (Interlocked.Decrement(ref _pendingNativeMombotEscapeEchoSuppressions) <= 0)
10123:            Interlocked.Exchange(ref _nativeMombotEscapeEchoSuppressUntilUtcTicks, 0);
10124:
10125:        return true;
10126:    }
