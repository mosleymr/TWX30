9151:    private string? BuildMombotStartupCorpUsersMessage()
9152:    {
9153:        string? botUsersPath = ResolveCurrentMombotBotUsersFilePath();
9154:        if (string.IsNullOrWhiteSpace(botUsersPath) || !File.Exists(botUsersPath))
9155:            return null;
9156:
9157:        string[] names = File.ReadLines(botUsersPath)
9158:            .Select(line => line.Trim())
9159:            .Where(line => !string.IsNullOrWhiteSpace(line))
9160:            .Distinct(StringComparer.OrdinalIgnoreCase)
9161:            .ToArray();
9162:        if (names.Length == 0)
9163:            return null;
9164:
9165:        string namesDisplay = names.Length switch
9166:        {
9167:            1 => names[0],
9168:            2 => $"{names[0]} and {names[1]}",
9169:            _ => $"{string.Join(", ", names.Take(names.Length - 1))}, and {names[^1]}"
9170:        };
9171:        string suffix = names.Length == 1 ? " is added.*" : " are added.*";
9172:        return $"'[General] {{{ReadCurrentMombotVar("mombot", "$SWITCHBOARD~BOT_NAME", "$SWITCHBOARD~bot_name", "$bot~bot_name", "$bot_name")}}} - Logging corp mates automatically - {namesDisplay}{suffix}";
9173:    }
