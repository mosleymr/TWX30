357:    private static string NormalizeLegacyInterrogLineForScripts(string line)
358:    {
359:        if (string.IsNullOrEmpty(line) || line[0] != ':')
360:            return line;
361:
362:        int index = 1;
363:        while (index < line.Length && char.IsWhiteSpace(line[index]))
364:            index++;
365:
366:        if (index >= line.Length)
367:            return line;
368:
369:        ReadOnlySpan<char> tail = line.AsSpan(index);
370:        if (tail.StartsWith("FM >", StringComparison.Ordinal) ||
371:            tail.StartsWith("TO >", StringComparison.Ordinal) ||
372:            tail.StartsWith("The shortest path (", StringComparison.Ordinal))
373:        {
374:            return line[index..];
375:        }
376:
377:        return line;
378:    }
