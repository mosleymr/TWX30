11089:    private static bool TryBuildRepeatedMacroPayload(byte[] payload, int count, out byte[] burstPayload, out string? error)
11090:    {
11091:        burstPayload = [];
11092:        error = null;
11093:
11094:        if (payload.Length == 0 || count <= 0)
11095:            return true;
11096:
11097:        long totalLength = (long)payload.Length * count;
11098:        if (totalLength > int.MaxValue)
11099:        {
11100:            error = "Macro burst is too large to send in one pass.";
11101:            return false;
11102:        }
11103:
11104:        if (count == 1)
11105:        {
11106:            burstPayload = payload;
11107:            return true;
11108:        }
11109:
11110:        burstPayload = new byte[(int)totalLength];
11111:        int offset = 0;
11112:        for (int i = 0; i < count; i++)
11113:        {
11114:            Buffer.BlockCopy(payload, 0, burstPayload, offset, payload.Length);
11115:            offset += payload.Length;
11116:        }
11117:
11118:        return true;
11119:    }
