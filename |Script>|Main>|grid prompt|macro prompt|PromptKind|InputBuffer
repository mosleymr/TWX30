7843:
7844:    private int StopScriptsMatchingTree(
7845:        string origin,
7846:        IReadOnlyList<string> directScriptPaths,
7847:        string? scriptRootPath,
7848:        string lastLoadedModule,
7849:        string scriptDirectory,
7850:        string programDir)
7851:    {
7852:        Core.ModInterpreter? interpreter = CurrentInterpreter;
7853:        if (interpreter == null)
7854:            return 0;
7855:
7856:        var normalizedDirectScripts = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
7857:        foreach (string directScript in directScriptPaths)
7858:        {
7859:            string normalized = NormalizeScriptStopPath(directScript, scriptDirectory, programDir);
7860:            if (!string.IsNullOrWhiteSpace(normalized))
7861:                normalizedDirectScripts.Add(normalized);
7862:        }
7863:
7864:        int totalStopped = 0;
7865:        for (int pass = 1; pass <= 3; pass++)
7866:        {
7867:            int stoppedThisPass = 0;
7868:            IReadOnlyList<Core.RunningScriptInfo> runningScripts = Core.ProxyGameOperations.GetRunningScripts(interpreter);
7869:            foreach (Core.RunningScriptInfo script in runningScripts)
7870:            {
7871:                string reference = string.IsNullOrWhiteSpace(script.Reference) ? script.Name : script.Reference;
7872:                if (!ShouldStopBotScript(reference, normalizedDirectScripts, scriptRootPath, lastLoadedModule, scriptDirectory, programDir))
7873:                    continue;
7874:
7875:                TraceRuntimeStop($"[BotStop] {origin} pass={pass} stopping ref='{reference}' display='{script.Name}'");
7876:                if (Core.ProxyGameOperations.StopScriptByName(interpreter, reference))
7877:                    stoppedThisPass++;
7878:            }
7879:
7880:            totalStopped += stoppedThisPass;
7881:            if (stoppedThisPass == 0)
7882:                break;
7883:        }
7884:
7885:        return totalStopped;
7886:    }
7887:
7888:    private static bool ShouldStopBotScript(
7889:        string reference,
7890:        HashSet<string> normalizedDirectScripts,
7891:        string? scriptRootPath,
7892:        string lastLoadedModule,
7893:        string scriptDirectory,
7894:        string programDir)
7895:    {
7896:        string normalizedReference = NormalizeScriptStopPath(reference, scriptDirectory, programDir);
7897:        if (normalizedDirectScripts.Contains(normalizedReference))
7898:            return true;
7899:
7900:        if (!string.IsNullOrWhiteSpace(scriptRootPath) && IsScriptUnderRoot(normalizedReference, scriptRootPath))
7901:            return true;
7902:
7903:        return !string.IsNullOrWhiteSpace(lastLoadedModule) &&
7904:               (ScriptReferenceMatches(reference, lastLoadedModule, scriptDirectory, programDir) ||
7905:                string.Equals(
7906:                    normalizedReference,
