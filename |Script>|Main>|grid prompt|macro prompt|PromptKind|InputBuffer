2066:        }
2067:        catch (Exception ex)
2068:        {
2069:            Core.GlobalModules.DebugLog(
2070:                $"[Skin] Failed to apply {(_useCommandDeckSkin ? "command deck" : "classic")} skin: {ex}\n");
2071:
2072:            if (_useCommandDeckSkin)
