9988:    private byte[] FilterTerminalDisplayArtifacts(byte[] chunk, out bool rewrotePromptOverwrite)
9989:    {
9990:        rewrotePromptOverwrite = false;
9991:        if (chunk.Length == 0)
9992:            return chunk;
9993:
9994:        lock (_terminalDisplayArtifactSync)
9995:        {
9996:            List<byte>? filtered = null;
9997:            int index = 0;
9998:
9999:            if (_pendingTerminalSyncMarkerLeadByte)
10000:            {
10001:                _pendingTerminalSyncMarkerLeadByte = false;
10002:
10003:                if (chunk[0] == 0x08)
10004:                {
10005:                    filtered = new List<byte>(Math.Max(0, chunk.Length - 1));
10006:                    index = 1;
10007:                }
10008:                else
10009:                {
10010:                    filtered = new List<byte>(chunk.Length + 1) { 0x91 };
10011:                }
10012:            }
10013:
10014:            for (; index < chunk.Length; index++)
10015:            {
10016:                byte value = chunk[index];
10017:
10018:                if (_suppressingPendingNativeMombotEscapeSequence)
10019:                {
10020:                    filtered ??= new List<byte>(chunk.Length);
10021:
10022:                    if (!_suppressingPendingNativeMombotEscapeCsiBody)
10023:                    {
10024:                        if (value == (byte)'[')
10025:                        {
10026:                            _suppressingPendingNativeMombotEscapeCsiBody = true;
10027:                            continue;
10028:                        }
10029:
10030:                        _suppressingPendingNativeMombotEscapeSequence = false;
10031:                        _suppressingPendingNativeMombotEscapeCsiBody = false;
10032:                        continue;
10033:                    }
10034:
10035:                    if (value >= 0x40 && value <= 0x7E)
10036:                    {
10037:                        _suppressingPendingNativeMombotEscapeSequence = false;
10038:                        _suppressingPendingNativeMombotEscapeCsiBody = false;
10039:                    }
10040:
10041:                    continue;
10042:                }
10043:
10044:                if (ShouldSuppressPendingNativeMombotEscapeEcho(value))
10045:                {
10046:                    filtered ??= new List<byte>(chunk.Length);
10047:                    _suppressingPendingNativeMombotEscapeSequence = true;
10048:                    _suppressingPendingNativeMombotEscapeCsiBody = false;
10049:                    continue;
10050:                }
10051:
10052:                if (value == 0x91)
10053:                {
10054:                    if (index + 1 < chunk.Length)
10055:                    {
10056:                        if (chunk[index + 1] == 0x08)
10057:                        {
10058:                            filtered ??= new List<byte>(chunk.Length);
10059:                            index++;
10060:                            continue;
10061:                        }
10062:                    }
10063:                    else
10064:                    {
10065:                        filtered ??= new List<byte>(chunk.Length);
10066:                        _pendingTerminalSyncMarkerLeadByte = true;
10067:                        continue;
10068:                    }
10069:                }
10070:
10071:                if (value == 0x1B &&
10072:                    index + 6 < chunk.Length &&
10073:                    chunk[index + 1] == (byte)'[' &&
10074:                    chunk[index + 2] == (byte)'K' &&
10075:                    chunk[index + 3] == 0x1B &&
10076:                    chunk[index + 4] == (byte)'[' &&
10077:                    chunk[index + 5] == (byte)'1' &&
10078:                    chunk[index + 6] == (byte)'A')
10079:                {
10080:                    filtered ??= new List<byte>(chunk.Length + 8);
10081:                    filtered.Add(0x0D);
10082:                    filtered.Add(0x1B);
10083:                    filtered.Add((byte)'[');
10084:                    filtered.Add((byte)'K');
10085:                    filtered.Add(0x1B);
10086:                    filtered.Add((byte)'[');
10087:                    filtered.Add((byte)'1');
10088:                    filtered.Add((byte)'A');
10089:                    filtered.Add(0x0D);
10090:                    filtered.Add(0x1B);
10091:                    filtered.Add((byte)'[');
10092:                    filtered.Add((byte)'K');
10093:                    rewrotePromptOverwrite = true;
10094:                    index += 6;
10095:                    continue;
10096:                }
10097:
10098:                filtered?.Add(value);
10099:            }
10100:
10101:            return filtered == null ? chunk : filtered.ToArray();
10102:        }
10103:    }
