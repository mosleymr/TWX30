4931:    private static string NormalizeScriptDirectoryValue(string? scriptDirectory)
4932:    {
4933:        if (string.IsNullOrWhiteSpace(scriptDirectory))
4934:            return string.Empty;
4935:
4936:        string trimmed = scriptDirectory.Trim();
4937:        try
4938:        {
4939:            trimmed = Path.GetFullPath(trimmed);
4940:        }
4941:        catch
4942:        {
4943:            // Keep the original text if it cannot be normalized yet.
4944:        }
4945:
4946:        return trimmed.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
4947:    }
