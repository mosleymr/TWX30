8537:
8538:        var buffer = new System.Text.StringBuilder(trimmed.Length);
8539:        foreach (char ch in trimmed)
8540:        {
8541:            if (char.IsLetterOrDigit(ch))
8542:                buffer.Append(char.ToLowerInvariant(ch));
8543:            else if (ch == '_' || ch == '-')
