5654:                    string remainderAnsi = bufferedAnsi[lastAnsiProcessedPos..];
5655:                    serverLineBuf.Clear();
5656:                    serverLineBuf.Append(remainder);
5657:                    serverAnsiLineBuf.Clear();
5658:                    serverAnsiLineBuf.Append(remainderAnsi);
