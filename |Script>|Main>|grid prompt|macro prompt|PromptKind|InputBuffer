4527:    private Core.DataHeader BuildResetDatabaseHeader(EmbeddedGameConfig config, Core.DataHeader sourceHeader)
4528:    {
4529:        string loginScript = string.IsNullOrWhiteSpace(config.LoginScript)
4530:            ? (string.IsNullOrWhiteSpace(sourceHeader.LoginScript) ? "0_Login.cts" : sourceHeader.LoginScript)
4531:            : config.LoginScript;
4532:
4533:        char gameLetter = !string.IsNullOrWhiteSpace(config.GameLetter)
4534:            ? char.ToUpperInvariant(config.GameLetter[0])
4535:            : sourceHeader.Game;
4536:
4537:        char commandChar = config.CommandChar == '\0'
4538:            ? (sourceHeader.CommandChar == '\0' ? '$' : sourceHeader.CommandChar)
4539:            : config.CommandChar;
4540:
4541:        int sectorCount = config.Sectors > 0
4542:            ? config.Sectors
4543:            : (sourceHeader.Sectors > 0 ? sourceHeader.Sectors : (_state.Sectors > 0 ? _state.Sectors : 1000));
4544:
4545:        int serverPort = config.Port > 0
4546:            ? config.Port
4547:            : (sourceHeader.ServerPort > 0 ? sourceHeader.ServerPort : _state.Port);
4548:
4549:        int listenPort = config.ListenPort > 0
4550:            ? config.ListenPort
4551:            : (sourceHeader.ListenPort > 0 ? sourceHeader.ListenPort : 2300);
4552:
4553:        return new Core.DataHeader
4554:        {
4555:            ProgramName = sourceHeader.ProgramName,
4556:            Version = sourceHeader.Version == 0 ? (byte)Core.DatabaseConstants.DatabaseVersion : sourceHeader.Version,
4557:            Sectors = sectorCount,
4558:            Address = string.IsNullOrWhiteSpace(config.Host)
4559:                ? (string.IsNullOrWhiteSpace(sourceHeader.Address) ? _state.Host : sourceHeader.Address)
4560:                : config.Host,
4561:            Description = sourceHeader.Description,
4562:            ServerPort = (ushort)Math.Clamp(serverPort, 0, ushort.MaxValue),
4563:            ListenPort = (ushort)Math.Clamp(listenPort, 0, ushort.MaxValue),
4564:            LoginScript = loginScript,
