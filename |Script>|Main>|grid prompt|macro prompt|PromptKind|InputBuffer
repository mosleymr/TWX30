2693:            var g = new Grid();
2694:            g.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(1, GridUnitType.Star) });
2695:            g.ColumnDefinitions.Add(new ColumnDefinition { Width = GridLength.Auto });
2696:            Grid.SetColumn(keyTb, 0); Grid.SetColumn(valTb, 1);
2697:            g.Children.Add(keyTb); g.Children.Add(valTb);
2698:            return g;
2699:        }
2700:        var row = new Grid { Margin = new Thickness(6, 1, 6, 1) };
2701:        row.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(1, GridUnitType.Star) });
2702:        row.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(4, GridUnitType.Pixel) });
2703:        row.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(1, GridUnitType.Star) });
2704:        var left = MakeHalf(k1, v1); var right = MakeHalf(k2, v2);
2705:        Grid.SetColumn(left, 0); Grid.SetColumn(right, 2);
2706:        row.Children.Add(left); row.Children.Add(right);
