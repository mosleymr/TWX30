9654:    private static bool TryLoadMombotHotkeyConfigFromFile(string configPath, out MombotHotkeyConfigData? config)
9655:    {
9656:        config = null;
9657:        try
9658:        {
9659:            if (!File.Exists(configPath))
9660:                return false;
9661:
9662:            string[] lines = File.ReadAllLines(configPath);
9663:            if (lines.Length != 33)
9664:                return false;
9665:
9666:            string[] customKeys = Enumerable.Repeat("0", 33).ToArray();
9667:            string[] customCommands = Enumerable.Repeat("0", 33).ToArray();
9668:            for (int lineIndex = 0; lineIndex < lines.Length; lineIndex++)
9669:            {
9670:                string line = lines[lineIndex].Trim();
9671:                if (string.IsNullOrWhiteSpace(line))
9672:                    return false;
9673:
9674:                string[] parts = line.Split('$');
9675:                int slot = lineIndex + 1;
9676:                string keyToken;
9677:                string commandToken;
9678:                if (parts.Length >= 3 && int.TryParse(parts[0].Trim(), out int explicitSlot))
9679:                {
9680:                    if (explicitSlot < 1 || explicitSlot > 33)
9681:                        return false;
9682:                    slot = explicitSlot;
9683:                    keyToken = parts[1].Trim();
9684:                    commandToken = string.Join("$", parts.Skip(2)).Trim();
9685:                }
9686:                else if (parts.Length >= 2)
9687:                {
9688:                    keyToken = parts[0].Trim();
9689:                    commandToken = string.Join("$", parts.Skip(1)).Trim();
9690:                }
9691:                else
9692:                {
9693:                    return false;
9694:                }
9695:
9696:                if (!TryDecodeMombotHotkeyToken(keyToken, out string normalizedKey))
9697:                    return false;
9698:
9699:                customKeys[slot - 1] = normalizedKey;
9700:                customCommands[slot - 1] = string.IsNullOrWhiteSpace(commandToken) ? "0" : commandToken;
9701:            }
9702:
9703:            config = new MombotHotkeyConfigData(
9704:                BuildMombotHotkeyIndex(customKeys),
9705:                customKeys,
9706:                customCommands);
9707:            return true;
9708:        }
9709:        catch
9710:        {
9711:            return false;
9712:        }
9713:    }
