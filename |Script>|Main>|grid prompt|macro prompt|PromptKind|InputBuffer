1069:    private IEnumerable<double> GetDeckHorizontalSnapTargets(FloatingDeckPanel movingPanel, double proposedLeft, double proposedTop, double movingWidth, double movingHeight)
1070:    {
1071:        yield return 0;
1072:        if (_deckSurface != null)
1073:            yield return Math.Max(0, _deckSurface.Bounds.Width - movingWidth);
1074:        yield return SnapToDeckGrid(proposedLeft);
1075:
1076:        foreach (FloatingDeckPanel panel in _deckPanels.Values)
1077:        {
1078:            if (panel == movingPanel || !panel.IsVisible)
1079:                continue;
1080:
1081:            (double left, double top) = panel.GetPosition();
1082:            double right = left + panel.PanelWidth;
1083:            double bottom = top + panel.PanelHeight;
1084:            if (!RangesOverlapOrNear(proposedTop, proposedTop + movingHeight, top, bottom, DeckPanelSnapThreshold * 2))
1085:                continue;
1086:
1087:            yield return left;
1088:            yield return right - movingWidth;
1089:            yield return right + DeckPanelSnapGap;
1090:            yield return left - movingWidth - DeckPanelSnapGap;
1091:        }
1092:    }
