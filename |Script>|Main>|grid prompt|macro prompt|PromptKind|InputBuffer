11786:            }
11787:
11788:            return true;
11789:        }
11790:
11791:        bool changed = false;
11792:        foreach (byte value in bytes)
11793:        {
11794:            switch (value)
11795:            {
11796:                case 0x08:
11797:                case 0x7F:
11798:                    if (_mombotPreferencesInputBuffer.Length > 0)
11799:                    {
11800:                        _mombotPreferencesInputBuffer = _mombotPreferencesInputBuffer[..^1];
11801:                        changed = true;
11802:                    }
11803:                    break;
11804:
11805:                case 0x1B:
11806:                    CancelMombotPreferencesInput();
11807:                    return true;
11808:
11809:                case 0x0D:
11810:                case 0x0A:
11811:                    CompleteMombotPreferencesInput(_mombotPreferencesInputBuffer);
11812:                    return true;
11813:
11814:                default:
11815:                    if (value >= 0x20)
11816:                    {
11817:                        _mombotPreferencesInputBuffer += (char)value;
11818:                        changed = true;
11819:                    }
11820:                    break;
11821:            }
11822:        }
11823:
11824:        if (changed)
11825:            RedrawMombotPrompt();
11826:
11827:        return true;
11828:    }
