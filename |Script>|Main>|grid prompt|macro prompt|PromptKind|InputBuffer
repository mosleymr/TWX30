7962:    private static string NormalizeScriptStopPath(string reference, string primaryBaseDir, string secondaryBaseDir)
7963:    {
7964:        if (string.IsNullOrWhiteSpace(reference))
7965:            return string.Empty;
7966:
7967:        string normalized = reference
7968:            .Trim()
7969:            .Replace('\\', Path.DirectorySeparatorChar)
7970:            .Replace('/', Path.DirectorySeparatorChar);
7971:
7972:        if (Path.IsPathRooted(normalized))
7973:        {
7974:            try
7975:            {
7976:                return Path.GetFullPath(normalized);
7977:            }
7978:            catch
7979:            {
7980:                return normalized;
7981:            }
7982:        }
7983:
7984:        foreach (string baseDir in new[] { primaryBaseDir, secondaryBaseDir })
7985:        {
7986:            if (string.IsNullOrWhiteSpace(baseDir))
7987:                continue;
7988:
7989:            try
7990:            {
7991:                return Path.GetFullPath(Path.Combine(baseDir, normalized));
7992:            }
7993:            catch
7994:            {
7995:            }
7996:        }
7997:
7998:        return normalized;
7999:    }
