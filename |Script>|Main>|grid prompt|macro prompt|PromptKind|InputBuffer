11066:    private static byte[] GetCombinedMacroPayload(IEnumerable<byte[]> chunks)
11067:    {
11068:        int totalLength = 0;
11069:        foreach (byte[] chunk in chunks)
11070:            totalLength += chunk.Length;
11071:
11072:        if (totalLength == 0)
11073:            return [];
11074:
11075:        byte[] payload = new byte[totalLength];
11076:        int offset = 0;
11077:        foreach (byte[] chunk in chunks)
11078:        {
11079:            if (chunk.Length == 0)
11080:                continue;
11081:
11082:            Buffer.BlockCopy(chunk, 0, payload, offset, chunk.Length);
11083:            offset += chunk.Length;
11084:        }
11085:
11086:        return payload;
11087:    }
