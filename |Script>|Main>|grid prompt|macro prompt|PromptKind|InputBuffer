12764:        if (string.IsNullOrEmpty(value))
12765:            return;
12766:
12767:        char selectedKey = value[0];
12768:        int lower = char.ToLowerInvariant(selectedKey);
12769:        int upper = char.ToUpperInvariant(selectedKey);
12770:        if ((lower >= '0' && lower <= '9') || selectedKey == '?')
12771:        {
12772:            PublishMombotLocalMessage("Hotkeys cannot use digits or '?'.");
12773:            return;
12774:        }
12775:
12776:        MombotHotkeyConfigData config = LoadMombotHotkeyConfigData();
12777:        string[] hotkeys = config.Hotkeys.ToArray();
12778:        string[] customKeys = config.CustomKeys.ToArray();
12779:        string[] customCommands = config.CustomCommands.ToArray();
12780:        string slotValue = slot.ToString();
12781:
12782:        if (!CanBindMombotHotkeyCode(hotkeys, lower, slotValue) || !CanBindMombotHotkeyCode(hotkeys, upper, slotValue))
12783:        {
12784:            PublishMombotLocalMessage("Hot key already bound to another function.");
12785:            return;
12786:        }
12787:
12788:        string existingKey = customKeys[slot - 1];
12789:        if (!string.IsNullOrEmpty(existingKey))
12790:        {
12791:            int existingLower = char.ToLowerInvariant(existingKey[0]);
12792:            int existingUpper = char.ToUpperInvariant(existingKey[0]);
12793:            ClearMombotHotkeyCode(hotkeys, existingLower, slotValue);
12794:            ClearMombotHotkeyCode(hotkeys, existingUpper, slotValue);
12795:        }
12796:
12797:        SetMombotHotkeyCode(hotkeys, lower, slotValue);
12798:        SetMombotHotkeyCode(hotkeys, upper, slotValue);
12799:        customKeys[slot - 1] = selectedKey.ToString();
12800:
12801:        if (slot > 17)
12802:        {
12803:            string currentCommand = customCommands[slot - 1] == "0" ? string.Empty : customCommands[slot - 1];
12804:            BeginMombotPreferencesInput(
12805:                $"Command For {GetMombotHotkeySlotLabel(slot)}",
12806:                command =>
12807:                {
12808:                    customCommands[slot - 1] = string.IsNullOrWhiteSpace(command) ? "0" : command.Trim();
12809:                    WriteMombotHotkeyConfig(new MombotHotkeyConfigData(hotkeys, customKeys, customCommands));
12810:                },
12811:                currentCommand);
12812:            return;
12813:        }
12814:
12815:        WriteMombotHotkeyConfig(new MombotHotkeyConfigData(hotkeys, customKeys, customCommands));
12816:    }
