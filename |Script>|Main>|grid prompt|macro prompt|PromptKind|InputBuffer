1031:    private void EnsureDeckPanelsInitialized()
1032:    {
1033:        if (_deckPanelsInitialized || _deckSurface == null || _deckSurface.Bounds.Width <= 0 || _deckSurface.Bounds.Height <= 0)
1034:            return;
1035:
1036:        _suppressDeckPanelStateSync = true;
1037:        try
1038:        {
1039:            foreach ((string panelId, FloatingDeckPanel panel) in _deckPanels)
1040:            {
1041:                if (_deckPanelStates.TryGetValue(panelId, out DeckPanelState? state))
1042:                    ApplyDeckPanelState(panel, state);
1043:            }
1044:        }
1045:        finally
1046:        {
1047:            _suppressDeckPanelStateSync = false;
1048:        }
1049:
1050:        _deckPanelsInitialized = true;
1051:        foreach (FloatingDeckPanel panel in _deckPanels.Values)
1052:            OnDeckPanelStateChanged(panel);
1053:
1054:        _appPrefs.Save();
1055:    }
