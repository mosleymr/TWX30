2085:                }
2086:
2087:                _parser.Feed($"\x1b[1;31m[Command Deck unavailable: {ex.Message}]\x1b[0m\r\n");
2088:                _buffer.Dirty = true;
2089:                return;
2090:            }
2091:
2092:            throw;
2093:        }
2094:    }
