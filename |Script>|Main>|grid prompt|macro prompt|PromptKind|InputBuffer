9752:    private static bool TryDecodeMombotHotkeyToken(string token, out string normalizedKey)
9753:    {
9754:        normalizedKey = "0";
9755:        string trimmed = (token ?? string.Empty).Trim();
9756:        if (string.IsNullOrWhiteSpace(trimmed) || trimmed == "0")
9757:            return true;
9758:
9759:        return trimmed.ToUpperInvariant() switch
9760:        {
9761:            "TAB" => AssignHotkey("\t", out normalizedKey),
9762:            "ENTER" => AssignHotkey("\r", out normalizedKey),
9763:            "BACKSPACE" => AssignHotkey("\b", out normalizedKey),
9764:            "SPACE" => AssignHotkey(" ", out normalizedKey),
9765:            _ => AssignHotkey(trimmed[..1], out normalizedKey),
9766:        };
9767:    }
