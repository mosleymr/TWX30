<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TWXP.ViewModels"
             x:Class="TWXP.GameConfigPage"
             Title="Game Configuration">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15" WidthRequest="500" HorizontalOptions="Center">
            
            <!-- Game Name -->
            <Label Text="Game Name" FontAttributes="Bold"/>
            <Entry Text="{Binding Name}" Placeholder="Enter game name"/>

            <!-- Game Settings -->
            <Label Text="Game Settings" FontAttributes="Bold" FontSize="18" Margin="0,20,0,0"/>
            
            <Label Text="Host"/>
            <Entry Text="{Binding Host}" Placeholder="localhost"/>
            
            <Label Text="Port"/>
            <Entry Text="{Binding Port}" Keyboard="Numeric" Placeholder="23"/>
            
            <Label Text="Listen Port"/>
            <Entry Text="{Binding ListenPort}" Keyboard="Numeric" Placeholder="2300"/>

            <Label Text="Proxy Menu Key"/>
            <Entry Text="{Binding CommandKey}" MaxLength="1" Placeholder="$"/>
            
            <Label Text="Sectors"/>
            <Entry Text="{Binding Sectors}" Keyboard="Numeric" Placeholder="1000"/>

            <Label Text="Script Directory (Global)"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Entry Grid.Column="0"
                       Text="{Binding ScriptDirectory}"
                       Placeholder="scripts"/>
                <Button Grid.Column="1"
                        Text="Browse"
                        Command="{Binding SelectScriptDirectoryCommand}"/>
            </Grid>
            <Label Text="Applies to all games in TWXP."
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
            
            <HorizontalStackLayout Spacing="10" Margin="0,20,0,0">
                <CheckBox IsChecked="{Binding AutoConnect}"/>
                <Label Text="Auto-connect on startup" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding AutoReconnect}"/>
                <Label Text="Auto-reconnect to the server" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Label Text="Reconnect Delay (seconds)"/>
            <Entry Text="{Binding ReconnectDelaySeconds}" Keyboard="Numeric" Placeholder="5"/>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding NativeHaggleEnabled}"/>
                <Label Text="Enable native haggle by default" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding UseCache}"/>
                <Label Text="Use database cache" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding LocalEcho}"/>
                <Label Text="Enable local echo" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Label Text="Bubble Size"/>
            <Entry Text="{Binding BubbleSize}" Keyboard="Numeric" Placeholder="25"/>

            <Label Text="Login Automation" FontAttributes="Bold" FontSize="18" Margin="0,20,0,0"/>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding UseLogin}"/>
                <Label Text="Run login script after connect" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding UseRLogin}"/>
                <Label Text="Use RLogin handshake" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <VerticalStackLayout Spacing="10" IsVisible="{Binding ShowLoginDetails}">
                <Label Text="Login Script"/>
                <Entry Text="{Binding LoginScript}" Placeholder="0_Login.cts"/>

                <Label Text="Username"/>
                <Entry Text="{Binding LoginName}" Placeholder="Trader name"/>

                <Label Text="Password"/>
                <Entry Text="{Binding Password}" IsPassword="True" Placeholder="Password"/>

                <Label Text="Game Letter"/>
                <Entry Text="{Binding GameLetter}" Placeholder="A"/>
            </VerticalStackLayout>

            <Label Text="Logging" FontAttributes="Bold" FontSize="18" Margin="0,20,0,0"/>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding LogEnabled}"/>
                <Label Text="Enable session logging" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding LogAnsi}"/>
                <Label Text="Store ANSI in logs" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding LogBinary}"/>
                <Label Text="Write binary capture files" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding NotifyPlayCuts}"/>
                <Label Text="Notify when playback is shortened" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Label Text="Maximum Playback Delay (ms)"/>
            <Entry Text="{Binding MaxPlayDelay}" Keyboard="Numeric" Placeholder="10000"/>

            <Label Text="Proxy / External" FontAttributes="Bold" FontSize="18" Margin="0,20,0,0"/>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding AcceptExternal}"/>
                <Label Text="Accept external connections" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding AllowLerkers}"/>
                <Label Text="Allow lerkers" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding BroadcastMessages}"/>
                <Label Text="Broadcast proxy messages" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding StreamingMode}"/>
                <Label Text="Streaming mode" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Label Text="External Address"/>
            <Entry Text="{Binding ExternalAddress}" Placeholder="Optional external address"/>

            <Label Text="Lerker Address"/>
            <Entry Text="{Binding LerkerAddress}" Placeholder="Optional lerker address"/>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,30,0,0">
                <Button Grid.Column="0" 
                        Text="Save"
                        Command="{Binding SaveCommand}"/>
                <Button Grid.Column="1"
                        Text="Cancel"
                        Clicked="OnCancelClicked"/>
            </Grid>

            <Button Text="Delete Game"
                    Command="{Binding DeleteCommand}"
                    BackgroundColor="{StaticResource Danger}"
                    Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
